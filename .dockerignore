# Docker ignore file — tells Docker what NOT to copy into the image
# Similar to .gitignore but for Docker builds

# Python virtual environment (large, not needed in container)
venv/

# Git metadata
.git/
.gitignore

# Python test files (not part of the web app)
test_form.py
conftest.py
requirements.txt

# Reports generated by pytest
reports/

# Jenkins pipeline file (not needed in container)
Jenkinsfile

# Project documentation
README.md
Krishna_GitHub_Link.txt

# Python cache
__pycache__/
*.pyc
*.pyo
